# Backend configuration (read by app/core/config.py). No secrets committed.

# --- Database: choose ONE of the two modes ---

# Mode 1 — full URL (what Render/Railway provide). Leave blank to use Mode 2.
#   Local Postgres:   postgresql+psycopg://user:pass@localhost:5432/inventory
#   Zero-setup local: sqlite:///./dev.db
#   Render/Railway provide postgres:// URLs which the app rewrites automatically.
DATABASE_URL=

# Mode 2 — individual parts (used when DATABASE_URL is blank). Docker Compose
# passes these. Passwords with special characters (@ : / ?) are escaped safely.
POSTGRES_USER=inventory
POSTGRES_PASSWORD=change_me_use_a_strong_secret
POSTGRES_DB=inventory
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Comma-separated allowed CORS origins, or * for all.
CORS_ORIGINS=*

# Low-stock dashboard threshold.
LOW_STOCK_THRESHOLD=10
