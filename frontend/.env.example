# Base URL the frontend uses to reach the backend API.
# - Local dev (vite):       leave as /api  (vite proxies to localhost:8000)
# - Docker Compose:         /api           (nginx proxies to the backend service)
# - Vercel/Netlify deploy:  full backend URL, e.g. https://your-api.onrender.com
VITE_API_URL=/api
