# Copy to .env and adjust. Used by docker-compose.yml.
# NEVER commit the real .env — it is gitignored.

# --- PostgreSQL ---
POSTGRES_USER=inventory
POSTGRES_PASSWORD=change_me_use_a_strong_secret
POSTGRES_DB=inventory

# --- Ports exposed on the host ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Backend ---
# Allowed CORS origins (comma-separated) or * for all. For Compose the frontend
# calls the backend through nginx so * is fine locally.
CORS_ORIGINS=*
# Products with stock at or below this count show as "low" on the dashboard.
LOW_STOCK_THRESHOLD=10
